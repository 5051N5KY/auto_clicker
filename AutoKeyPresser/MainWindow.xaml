<Window x:Class="AutoKeyPresser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Key Presser" Width="520" Height="592" MinWidth="500" MinHeight="572"
        WindowStartupLocation="CenterScreen" Background="#0F1117" Foreground="#E8ECF3">
    <Window.Resources>
        <SolidColorBrush x:Key="FieldBackground" Color="#20242E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#343A48"/>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#E8ECF3"/></Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/><Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="CaretBrush" Value="White"/><Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="8,4" VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left" RecognizesAccessKey="True"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#F5F7FA"/>
                                                <Path Grid.Column="1" Width="8" Height="5" Stretch="Fill" Fill="#B8C0CF"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ToggleBorder" Property="Background" Value="#292F3B"/></Trigger>
                                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#20242E" BorderBrush="#50596B" BorderThickness="1" Padding="2">
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#20242E"/><Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="Padding" Value="8,5"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#35445D"/><Setter Property="Foreground" Value="White"/></Trigger>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#266D9A"/><Setter Property="Foreground" Value="White"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox"><Setter Property="Margin" Value="0,5"/><Setter Property="Foreground" Value="#E8ECF3"/></Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#2A303C"/><Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="BorderBrush" Value="#424A5A"/>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171A21" CornerRadius="10" Padding="18" BorderBrush="#303642" BorderThickness="1">
            <StackPanel x:Name="ConfigurationPanel">
                    <TextBlock Text="Key" FontWeight="SemiBold"/>
                    <DockPanel Margin="0,6,0,14">
                        <Border Background="#252A35" CornerRadius="5" Padding="12,8" MinWidth="150">
                            <TextBlock x:Name="SelectedKeyText" Text="1" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <Button x:Name="SelectKeyButton" Content="Select key" Click="SelectKey_Click" HorizontalAlignment="Left"/>
                    </DockPanel>

                    <TextBlock Text="Interval" FontWeight="SemiBold"/>
                    <Grid Margin="0,6,0,10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="135"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="IntervalTextBox" Text="1000" Margin="0,0,8,0"/>
                        <ComboBox x:Name="IntervalUnitCombo" Grid.Column="1" SelectedIndex="0"><ComboBoxItem Content="milliseconds"/><ComboBoxItem Content="seconds"/></ComboBox>
                    </Grid>

                    <CheckBox x:Name="RandomCheckBox" Content="Random deviation" Checked="RandomChanged" Unchecked="RandomChanged"/>
                    <DockPanel Margin="22,2,0,10"><TextBlock Text="&#177;" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox x:Name="DeviationTextBox" Text="100" Width="100"/><TextBlock Text=" ms" VerticalAlignment="Center"/></DockPanel>

                    <TextBlock Text="Start delay (seconds)" FontWeight="SemiBold"/>
                    <TextBox x:Name="StartDelayTextBox" Text="3" Width="110" HorizontalAlignment="Left" Margin="0,6,0,12"/>

                    <TextBlock Text="Stop mode" FontWeight="SemiBold"/>
                    <ComboBox x:Name="LimitModeCombo" SelectedIndex="0" Margin="0,6,0,6" SelectionChanged="LimitModeChanged">
                        <ComboBoxItem Content="No limit"/><ComboBoxItem Content="After a number of presses"/><ComboBoxItem Content="After a set time"/>
                    </ComboBox>
                    <DockPanel x:Name="LimitValuePanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBox x:Name="LimitValueTextBox" Text="100" Width="110" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="LimitUnitText" Text=" presses" VerticalAlignment="Center"/>
                    </DockPanel>

                    <CheckBox x:Name="StopOnOtherKeyCheckBox" Content="Stop when another key is pressed" IsChecked="True"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Button x:Name="StartButton" Content="Start" Click="Start_Click" Background="#2EA66A" Foreground="White" BorderBrush="#2EA66A" FontWeight="SemiBold" FontSize="15"/>
                <Button x:Name="StopButton" Grid.Column="1" Content="Stop" Click="Stop_Click" IsEnabled="False" FontWeight="SemiBold" FontSize="15"/>
            </Grid>
            <Border Background="#171A21" BorderBrush="#303642" BorderThickness="1" CornerRadius="7" Padding="12" Margin="4,7,4,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Status" Foreground="#8F98AA"/><TextBlock x:Name="StatusText" Text="Stopped" FontWeight="SemiBold"/></StackPanel>
                    <StackPanel Grid.Column="1"><TextBlock Text="Presses" Foreground="#8F98AA" HorizontalAlignment="Center"/><TextBlock x:Name="CounterText" Text="0" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Next press" Foreground="#8F98AA" HorizontalAlignment="Right"/><TextBlock x:Name="CountdownText" Text="--" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/></StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Margin="0,9,0,0" Foreground="#8F98AA" FontSize="11">
            <Run Text="Made with &lt;3 by "/>
            <Hyperlink NavigateUri="https://github.com/5051N5KY" RequestNavigate="OpenLink" Foreground="#67B7FF">Sosinsky</Hyperlink>
            <Run Text=". Buy me a "/>
            <Hyperlink NavigateUri="https://buycoffee.to/sosinsky" RequestNavigate="OpenLink" Foreground="#67B7FF">coffee</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
