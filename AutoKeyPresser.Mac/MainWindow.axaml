<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AutoKeyPresser.Mac.MainWindow"
        Title="Auto Key Presser" Width="520" Height="700" MinWidth="500" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="#0F1117">
  <Window.Styles>
    <Style Selector="TextBlock"><Setter Property="Foreground" Value="#E8ECF3"/></Style>
    <Style Selector="TextBox"><Setter Property="Background" Value="#20242E"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="BorderBrush" Value="#343A48"/><Setter Property="Padding" Value="8,5"/></Style>
    <Style Selector="ComboBox"><Setter Property="Background" Value="#20242E"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="BorderBrush" Value="#343A48"/><Setter Property="Padding" Value="6,4"/></Style>
    <Style Selector="Button"><Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4"/></Style>
    <Style Selector="CheckBox"><Setter Property="Foreground" Value="#E8ECF3"/><Setter Property="Margin" Value="0,5"/></Style>
  </Window.Styles>
  <Grid Margin="24" RowDefinitions="*,Auto,Auto">
    <Border Grid.Row="0" Background="#171A21" CornerRadius="10" Padding="18" BorderBrush="#303642" BorderThickness="1">
      <StackPanel x:Name="ConfigurationPanel" Spacing="6">
        <TextBlock Text="Key" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Border Background="#252A35" CornerRadius="5" Padding="12,8" MinWidth="150"><TextBlock x:Name="SelectedKeyText" Text="1" FontSize="16" FontWeight="SemiBold"/></Border>
          <Button x:Name="SelectKeyButton" Content="Select key" Click="SelectKey_Click"/>
          <Button x:Name="CancelKeyButton" Content="Cancel" Click="CancelKey_Click" IsVisible="False"/>
        </StackPanel>

        <TextBlock Text="Interval" FontWeight="SemiBold"/>
        <Grid ColumnDefinitions="*,135" Margin="0,0,0,4">
          <TextBox x:Name="IntervalTextBox" Text="1000" TextChanged="NumericTextChanged" Margin="0,0,8,0"/>
          <ComboBox x:Name="IntervalUnitCombo" Grid.Column="1" SelectedIndex="0"><ComboBoxItem Content="milliseconds"/><ComboBoxItem Content="seconds"/></ComboBox>
        </Grid>

        <CheckBox x:Name="RandomCheckBox" Content="Random deviation" IsCheckedChanged="RandomChanged"/>
        <StackPanel Orientation="Horizontal" Margin="22,0,0,4"><TextBlock Text="±" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox x:Name="DeviationTextBox" Text="100" Width="100" TextChanged="NumericTextChanged"/><TextBlock Text=" ms" VerticalAlignment="Center"/></StackPanel>

        <TextBlock Text="Start delay (seconds)" FontWeight="SemiBold"/>
        <TextBox x:Name="StartDelayTextBox" Text="3" Width="110" HorizontalAlignment="Left" TextChanged="NumericTextChanged" Margin="0,0,0,6"/>

        <TextBlock Text="Stop mode" FontWeight="SemiBold"/>
        <ComboBox x:Name="LimitModeCombo" SelectedIndex="0" SelectionChanged="LimitModeChanged">
          <ComboBoxItem Content="No limit"/><ComboBoxItem Content="After a number of presses"/><ComboBoxItem Content="After a set time"/>
        </ComboBox>
        <StackPanel x:Name="LimitValuePanel" Orientation="Horizontal" IsVisible="False" Margin="0,0,0,4">
          <TextBox x:Name="LimitValueTextBox" Text="100" Width="110" TextChanged="NumericTextChanged"/>
          <ComboBox x:Name="LimitTimeUnitCombo" Width="135" Margin="8,0,0,0" SelectedIndex="1" IsVisible="False"><ComboBoxItem Content="milliseconds"/><ComboBoxItem Content="seconds"/></ComboBox>
          <TextBlock x:Name="LimitUnitText" Text=" presses" VerticalAlignment="Center"/>
        </StackPanel>
        <CheckBox x:Name="StopOnOtherKeyCheckBox" Content="Stop when another key is pressed" IsChecked="True"/>
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="1" Margin="0,12,0,0">
      <Grid ColumnDefinitions="*,*">
        <Button x:Name="StartButton" Content="Start" Click="Start_Click" Background="#2EA66A" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
        <Button x:Name="StopButton" Grid.Column="1" Content="Stop" Click="Stop_Click" IsEnabled="False" FontWeight="SemiBold" FontSize="15"/>
      </Grid>
      <Border Background="#171A21" BorderBrush="#303642" BorderThickness="1" CornerRadius="7" Padding="12" Margin="4,7,4,0">
        <Grid ColumnDefinitions="*,*,*">
          <StackPanel><TextBlock Text="Status" Foreground="#8F98AA"/><TextBlock x:Name="StatusText" Text="Stopped" FontWeight="SemiBold"/></StackPanel>
          <StackPanel Grid.Column="1"><TextBlock Text="Presses" Foreground="#8F98AA" HorizontalAlignment="Center"/><TextBlock x:Name="CounterText" Text="0" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/></StackPanel>
          <StackPanel Grid.Column="2"><TextBlock Text="Next press" Foreground="#8F98AA" HorizontalAlignment="Right"/><TextBlock x:Name="CountdownText" Text="--" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/></StackPanel>
        </Grid>
      </Border>
    </StackPanel>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,9,0,0">
      <TextBlock Text="Crafted with ♥ by Sosinsky  •  Support the project —  " Foreground="#8F98AA" FontSize="11"/>
      <Button Content="Buy me a coffee ☕" Click="Coffee_Click" Padding="0" Margin="0" Foreground="#E6B85C" Background="Transparent" BorderThickness="0" FontSize="11"/>
    </StackPanel>
  </Grid>
</Window>
